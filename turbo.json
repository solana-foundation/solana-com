{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "eslint.config.*",
    "packages/config-eslint/**",
    ".prettierrc*",
    "lint-staged.config.*"
  ],
  "globalEnv": [
    "CODE_RUN_SERVER_URL",
    "DEVELOPER_CONTENT_API_KEY",
    "DEVELOPER_DATA_API_KEY",
    "DEVELOPER_DATA_API_URL",
    "CI",
    "EDGE_CONFIG",
    "INKEEP_API_KEY",
    "LINGODOTDEV_API_KEY",
    "LINGO_API_KEY",
    "NEXT_PUBLIC_INKEEP_API_KEY",
    "LUMA_PRIVATE_API_KEY",
    "MIRROR_API_KEY",
    "NEXT_PUBLIC_APP_NAME",
    "NEXT_PUBLIC_BUILDER_API_KEY",
    "NEXT_PUBLIC_ACCELERATE_APP_URL",
    "NEXT_PUBLIC_BREAKPOINT_APP_URL",
    "NEXT_PUBLIC_DOCS_APP_URL",
    "NEXT_PUBLIC_MEDIA_APP_URL",
    "NEXT_PUBLIC_MAIN_SITE_URL",
    "NEXT_RUNTIME",
    "NODE_ENV",
    "MEDIA_APP_URL",
    "PLAYWRIGHT_BASE_URL",
    "PLAYWRIGHT_STORAGE_STATE",
    "RIVER_KEY",
    "ANALYZE",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING",
    "SIMPLECAST_API_KEY",
    "SIMPLECAST_PODCAST_ID",
    "TEMPLATES_APP_URL",
    "KEYSTATIC_LOCAL",
    "KEYSTATIC_GITHUB_CLIENT_ID",
    "KEYSTATIC_GITHUB_CLIENT_SECRET",
    "KEYSTATIC_SECRET",
    "NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG",
    "TXTX_SURFNET_URL",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "YOUTUBE_API_KEY",
    "YOUTUBE_CHANNEL_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": [],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "outputs": []
    }
  }
}
