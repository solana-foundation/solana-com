    "react-dom": "catalog:",
    "rtl-detect": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
