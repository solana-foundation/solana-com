{
  "name": "solana-com-breakpoint",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3005",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm exec eslint . && pnpm -w exec prettier --ignore-path .prettierignore --check apps/breakpoint",
    "lint:fix": "pnpm exec eslint --fix . && pnpm -w exec prettier --ignore-path .prettierignore --write apps/breakpoint",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf node_modules .next coverage"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.11.0",
    "@solana-com/fab-menu": "workspace:*",
    "@solana-com/ui-chrome": "workspace:*",
    "@workspace/i18n": "workspace:*",
    "@workspace/sentry": "workspace:*",
    "next": "catalog:",
    "next-intl": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rtl-detect": "^1.1.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.7.9",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
    "@types/rtl-detect": "^1.0.3",
    "@workspace/config-eslint": "workspace:*",
    "@workspace/config-typescript": "workspace:*",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.15.1"
}
