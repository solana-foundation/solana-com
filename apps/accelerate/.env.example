# Google Sheets API (for reading sponsor and speaker data)
GOOGLE_SHEETS_API_KEY=

# Google Sheet configuration (for sponsors)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=

# Google Sheet configuration (for speakers)
# Optional - defaults to the Accelerate APAC Speaker Card sheet
GOOGLE_SHEET_ID_SPEAKERS=
GOOGLE_SHEET_NAME_SPEAKERS=

# Google Service Account (for downloading logos and photos from Drive)
# Required for downloading images from Google Drive folders
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=

# Airtable API (for Miami speakers carousel)
# Requires a personal access token with read access to the base
AIRTABLE_PAT=
AIRTABLE_BASE_ID_SPEAKERS=apph4y5MDXBxJ2uZy
AIRTABLE_TABLE_ID_SPEAKERS=tbljHJh3sx1zrwMSD
AIRTABLE_VIEW_ID_SPEAKERS=viwK6atCbxFZWGyvk
