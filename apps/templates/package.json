{
  "name": "solana-templates",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm exec eslint . && pnpm -w exec prettier --ignore-path .prettierignore --check apps/templates",
    "lint:fix": "pnpm exec eslint --fix . && pnpm -w exec prettier --ignore-path .prettierignore --write apps/templates",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "i18n:lingo": "pnpm --dir ../.. i18n:app templates",
    "clean": "node ../../scripts/clean.mjs ."
  },
  "dependencies": {
    "@inkeep/cxkit-react": "^0.5.117",
    "@solana-com/ui-chrome": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/og": "^0.8.6",
    "@workspace/i18n": "workspace:*",
    "@workspace/ui": "workspace:*",
    "classnames": "^2.5.1",
    "framer-motion": "^12.23.28",
    "lucide-react": "^0.528.0",
    "marked": "^16.4.2",
    "next": "catalog:",
    "next-intl": "catalog:",
    "nuqs": "^2.4.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-feather": "^2.0.10",
    "rtl-detect": "^1.1.2",
    "sanitize-html": "^2.17.5",
    "shiki": "^3.13.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^22.7.9",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
    "@types/rtl-detect": "^1.0.3",
    "@types/sanitize-html": "^2.16.1",
    "@workspace/config-eslint": "workspace:*",
    "@workspace/config-typescript": "workspace:*",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.4.49",
    "sass": "^1.92.1",
    "tailwindcss": "^3.4.19",
    "typescript": "5.8.3",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.15.1"
}
