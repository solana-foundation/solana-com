{
  "name": "solana-com-media",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm exec eslint . && pnpm -w exec prettier --ignore-path .prettierignore --check apps/media",
    "lint:fix": "pnpm exec eslint . --fix && pnpm -w exec prettier --ignore-path .prettierignore --write apps/media",
    "lint:content": "pnpm exec eslint content/**/*.mdx --fix",
    "optimize:images": "node scripts/optimize-images.mjs",
    "check:images": "node scripts/check-images.mjs",
    "dedupe:links": "node scripts/dedupe-links.mjs",
    "i18n:lingo": "pnpm --dir ../.. i18n:app media",
    "clean": "node ../../scripts/clean.mjs .",
    "check-types": "next typegen && tsc --noEmit",
    "typecheck": "pnpm run check-types",
    "test": "vitest run",
    "screenshots": "playwright test e2e/walkthrough-screenshots.spec.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@keystatic/core": "^0.5.50",
    "@keystatic/next": "^5.0.4",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.11.0",
    "@solana-com/ui-chrome": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@workspace/i18n": "workspace:*",
    "@workspace/sentry": "workspace:*",
    "@workspace/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.21",
    "dompurify": "3.2.7",
    "feed": "^4.2.2",
    "katex": "^0.17.0",
    "lucide-react": "^0.484.0",
    "mermaid": "^11.16.0",
    "motion": "^12.23.28",
    "next": "catalog:",
    "next-intl": "catalog:",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-icons": "^5.5.0",
    "react-player": "^2.16.1",
    "react-tweet": "^3.3.0",
    "react-use-measure": "^2.1.7",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "rtl-detect": "^1.1.2",
    "server-only": "^0.0.1",
    "shiki": "^3.11.0",
    "styled-jsx": "^5.1.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.8",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@svgr/webpack": "^8.1.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.13.3",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
    "@types/rtl-detect": "^1.0.3",
    "@workspace/config-eslint": "workspace:*",
    "@workspace/config-typescript": "workspace:*",
    "autoprefixer": "^10.4.27",
    "eslint-plugin-mdx": "^3.7.0",
    "postcss": "^8.5.15",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^13.0.2",
    "sharp": "^0.33.5",
