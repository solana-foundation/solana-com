# === Development Mode ===
# Set to 'true' for local development (uses local filesystem instead of GitHub)
NEXT_PUBLIC_KEYSTATIC_LOCAL=true

# === Keystatic GitHub App ===
# These are auto-generated when you run the Keystatic setup flow:
# 1. Deploy with GitHub storage enabled (NEXT_PUBLIC_KEYSTATIC_LOCAL unset or false)
# 2. Visit /keystatic and click "Create GitHub App"
# 3. Keystatic generates these env vars automatically
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# === Cross-app navigation ===
# Set this to the main site URL so header/footer links navigate correctly
# Production: https://solana.com
# Preview: https://solana-com-git-[branch].vercel.app
# Local dev: http://localhost:3000
NEXT_PUBLIC_MAIN_SITE_URL=https://solana.com

## Inkeep Analytics to collect feedback on docs
INKEEP_API_KEY=
## Inkeep widget (client-side)
NEXT_PUBLIC_INKEEP_API_KEY=
