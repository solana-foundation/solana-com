{
  "name": "@solana-com/fab-menu",
  "version": "0.1.3",
  "description": "Floating action button menu for Solana properties and external sites.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/solana-foundation/solana-com.git",
    "directory": "packages/fab-menu"
  },
  "keywords": [
    "solana",
    "fab",
    "menu",
    "react"
  ],
  "engines": {
    "node": ">=20"
  },
  "private": false,
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "pnpm exec eslint . --max-warnings 0",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^19.1.2",
    "react-dom": "^19.1.2"
  },
  "devDependencies": {
    "@workspace/config-eslint": "workspace:*",
    "@workspace/config-typescript": "workspace:*",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.14",
    "tsup": "^8.4.0",
    "typescript": "catalog:"
  }
}
