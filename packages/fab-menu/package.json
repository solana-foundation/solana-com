{
  "name": "@solana-com/fab-menu",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react-wrapper.d.ts",
      "import": "./dist/react-wrapper.js"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.js"
    }
  },
  "files": [
    "dist"
  ],
  "private": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "pnpm exec eslint . --max-warnings 0"
  },
  "dependencies": {
    "preact": "^10.25.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.14",
    "@workspace/config-typescript": "workspace:*",
    "typescript": "catalog:"
  }
}
