{
  "name": "@workspace/docs-examples",
  "version": "0.0.0",
  "private": true,
  "description": "Tested code examples that the docs app transcludes via @devrelkit/remark-include-code. Every snippet rendered in apps/docs/content/cookbook is sourced from a real file here, exercised against a local surfpool on every CI run.",
