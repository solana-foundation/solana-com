{
  "name": "@workspace/i18n",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "lint": "pnpm exec eslint . --max-warnings 0 && pnpm -w exec prettier --ignore-path .prettierignore --check packages/i18n",
    "lint:fix": "pnpm exec eslint --fix . && pnpm -w exec prettier --ignore-path .prettierignore --write packages/i18n",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "i18n:lingo": "npx lingo.dev@latest run"
  },
  "devDependencies": {
    "@workspace/config-eslint": "workspace:*",
    "@workspace/config-typescript": "workspace:*",
    "@types/node": "^22.7.9",
    "@types/react": "^19.0.14",
    "@types/react-dom": "^19.0.6",
    "typescript": "5.8.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "next": "catalog:",
    "next-intl": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
