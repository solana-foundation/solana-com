{
  "version": "1.15",
  "$schema": "https://lingo.dev/schema/i18n.json",
  "locale": {
    "source": "en",
    "targets": [
      "en",
      "ar",
      "de",
      "el",
      "es",
      "fi",
      "fr",
      "id",
      "it",
      "ja",
      "ko",
      "nl",
      "pl",
      "pt",
      "ru",
      "tr",
      "uk",
      "vi",
      "zh"
    ]
  },
  "buckets": {
    "json": {
      "lockedKeys": ["pages"],
      "include": [
        "messages/web/[locale]/*.json",
        "messages/accelerate/[locale]/*.json",
        "messages/media/[locale]/*.json",
        "messages/templates/[locale]/*.json"
      ]
    }
  }
}
