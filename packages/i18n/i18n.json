{
  "version": 1.8,
  "$schema": "https://lingo.dev/schema/i18n.json",
  "locale": {
    "source": "en",
    "targets": [
      "en",
      "ar",
      "de",
      "el",
      "es",
      "fi",
      "fr",
      "hi",
      "id",
      "it",
      "ja",
      "ko",
      "nl",
      "pl",
      "pt",
      "ru",
      "tr",
      "uk",
      "vi",
      "zh"
    ]
  },
  "buckets": {
    "web": {
      "lockedKeys": ["pages"],
      "include": ["messages/web/[locale]/*.json"]
    },
    "accelerate": {
      "include": ["messages/accelerate/[locale]/*.json"]
    },
    "media": {
      "lockedKeys": ["pages"],
      "include": ["messages/media/[locale]/*.json"]
    },
    "templates": {
      "include": ["messages/templates/[locale]/*.json"]
    }
  }
}
