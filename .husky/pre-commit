pnpm exec lint-staged

# Secrets scan on staged changes (SDLC §3.3). CI runs the authoritative
# blocking scan; this catches leaks before they ever reach a commit.
# Install locally with: brew install gitleaks
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --redact
else
  echo "warning: gitleaks not installed; skipping local secrets scan (CI will enforce it)"
fi
